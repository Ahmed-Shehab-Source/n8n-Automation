    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.candidates[0].content.parts[0].text;\nconst jsonMatch = raw.match(/\\{[\\s\\S]*\\}/);\n\nlet parsed;\ntry {\n  parsed = JSON.parse(jsonMatch[0]);\n} catch(e) {\n  return [{ json: { error: true, raw_response: raw } }];\n}\n\nparsed.generated_at = new Date().toISOString();\n\nreturn [{ json: parsed }];"
      },
