        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=YOUR_GEMINI_API_KEY_HERE",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are an AI CFO analyzing a small business financial health. Based on this 30-day summary, return ONLY a valid JSON object with no markdown: { \\\"health_score\\\": \\\"Healthy\\\" or \\\"Warning\\\" or \\\"Critical\\\", \\\"summary\\\": string (2 sentences max), \\\"recommendation_1\\\": string, \\\"recommendation_2\\\": string, \\\"recommendation_3\\\": string }. Financial data - Period: {{ $json.period }}, Total Income: {{ $json.total_income }} EGP, Total Expenses: {{ $json.total_expense }} EGP, Net Balance: {{ $json.net_balance }} EGP, Expense to Income Ratio: {{ $json.expense_to_income_ratio }}, Transaction Count: {{ $json.transaction_count }}\"\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
