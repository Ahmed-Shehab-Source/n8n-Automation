    {
      "parameters": {
        "jsCode": "const rows = $input.all();\nconst now = Date.now();\nconst thirtyDays = 30 * 24 * 60 * 60 * 1000;\n\nconst recent = rows.filter(r => {\n  const ts = new Date(r.json.timestamp).getTime();\n  return (now - ts) < thirtyDays;\n});\n\nlet totalIncome = 0, totalExpense = 0;\nconst categories = {};\n\nrecent.forEach(r => {\n  const amount = parseFloat(r.json.amount) || 0;\n  if (r.json.type === 'income') totalIncome += amount;\n  if (r.json.type === 'expense') totalExpense += amount;\n  \n  const cat = r.json.category || 'Unknown';\n  categories[cat] = (categories[cat] || 0) + amount;\n});\n\nconst netBalance = totalIncome - totalExpense;\nconst expenseToIncomeRatio = totalIncome > 0 \n  ? (totalExpense / totalIncome).toFixed(2) \n  : 'N/A';\n\nreturn [{\n  json: {\n    period: 'Last 30 days',\n    total_income: totalIncome,\n    total_expense: totalExpense,\n    net_balance: netBalance,\n    expense_to_income_ratio: expenseToIncomeRatio,\n    transaction_count: recent.length,\n    top_categories: JSON.stringify(categories),\n    generated_at: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        384,
        0
      ],
